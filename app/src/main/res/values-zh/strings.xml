    <!-- Help Center Content -->
    <string name="help_center_title">帮助中心</string>
    <string name="help_search_placeholder">我们能帮您什么？</string>
    <string name="popular_questions">热门问题</string>
    
    <string name="faq_q1">如何取消订阅？</string>
    <string name="faq_a1">您可以前往订阅详情页面，点击底部的“取消订阅”按钮。此操作仅终止应用内的追踪，请不要忘记在服务提供商处也进行取消。</string>
    
    <string name="faq_q2">我的数据安全吗？</string>
    <string name="faq_a2">是的，您的所有数据都加密存储在您的设备上。订阅追踪器不会与第三方分享您的个人数据。</string>
    
    <string name="faq_q3">如何连接我的银行账户？</string>
    <string name="faq_a3">目前，我们提供通过短信和通知读取权限进行的自动追踪，而不是直接的银行集成。银行集成即将推出。</string>
    
    <string name="faq_q4">我可以获得退款吗？</string>
    <string name="faq_a4">Google Play/App Store 的政策适用于应用内购买。您可以通过相应的商店提交退款请求。</string>
    
    <string name="faq_q5">提醒功能不起作用，我该怎么办？</string>
    <string name="faq_a5">请确保在设备设置中启用了应用的通知权限。此外，请检查省电模式是否未阻止通知。</string>
    
    <string name="faq_q6">什么是可疑交易通知？</string>
    <string name="faq_a6">当应用检测到超出您正常支出模式的支付或无法识别的费用时，它会向您发出警告。您可以在“可疑交易”屏幕上查看这些交易。</string>

    <!-- Privacy Policy Content -->
    <string name="privacy_policy_title">隐私政策</string>
    <string name="privacy_last_updated">最后更新日期：2026年2月20日</string>
    
    <string name="privacy_title_1">1. 简介</string>
    <string name="privacy_content_1">作为订阅追踪器（“本应用”），我们重视您的隐私。本隐私政策解释了在使用我们的应用程序时如何收集、使用和保护您的数据。</string>
    
    <string name="privacy_title_2">2. 收集的数据</string>
    <string name="privacy_content_2">我们的应用程序可能会收集或处理以下数据，以便为您提供更好的服务：\n\n• 订阅信息：您添加的订阅的名称、价格和扣费日期。\n• 使用数据：应用内交互和偏好。\n• 设备信息：应用程序运行所需的基本设备标识符。</string>
    
    <string name="privacy_title_3">3. 数据使用</string>
    <string name="privacy_content_3">收集的数据仅用于以下目的：\n\n• 让您能够追踪您的订阅。\n• 为接下来的扣费日期发送提醒通知。\n• 改进应用性能并修复错误。</string>
    
    <string name="privacy_title_4">4. 数据安全</string>
    <string name="privacy_content_4">您的个人数据安全地存储在您的设备上。存储在我们服务器上的数据（如果您创建了账户）受行业标准加密方法的保护。未经您的许可，您的数据绝不会被出售或与第三方分享。</string>
    
    <string name="privacy_title_5">5. 权限</string>
    <string name="privacy_content_5">应用程序可能会请求通知权限以向您发送通知。此权限仅用于订阅提醒。</string>
    
    <string name="privacy_title_6">6. 联系方式</string>
    <string name="privacy_content_6">有关我们隐私政策的问题，您可以通过以下方式联系我们：\ngokhanaytekinn@yandex.com</string>
</resources>
