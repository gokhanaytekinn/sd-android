    <string name="popular_questions">Mashhur savollar</string>
    
    <string name="faq_q1">Obunani qanday bekor qilish mumkin?</string>
    <string name="faq_a1">Obuna sahifasiga kirib, eng pastdagi \'Obunani bekor qilish\' tugmasini bosing. Bu faqat ilovadagi kuzatishni toʻxtatadi, xizmat koʻrsatuvchi orqali ham bekor qilishni unutmang.</string>
    
    <string name="faq_q2">Maʼlumotlarim xavfsizimi?</string>
    <string name="faq_a2">Ha, barcha maʼlumotlar qurilmangizda shifrlangan holatda saqlanadi. Biz maʼlumotlaringizni uchinchi shaxslarga bermaymiz.</string>
    
    <string name="faq_q3">Bank kartasini qanday ulash mumkin?</string>
    <string name="faq_a3">Hozirda SMS va bildirishnomalarni oʻqish orqali avtomatik kuzatish amalga oshiriladi. Bank integratsiyasi yaqin orada qoʻshiladi.</string>
    
    <string name="faq_q4">Toʻlovni qaytarib olsam boʻladimi?</string>
    <string name="faq_a4">Ilova ichidagi xaridlar boʻyicha Google Play/App Store qoidalari amal qiladi. Savollar boʻyicha rasmiy doʻkonlarga murojaat qilishingiz mumkin.</string>
    
    <string name="faq_q5">Eslatmalar ishlamayapti, nima qilish kerak?</string>
    <string name="faq_a5">Sozlamalardan bildirishnomalar yoqilganligini tekshiring. Shuningdek, quvvat tejash rejimi bunga toʻsqinlik qilmayotganiga ishonch hosil qiling.</string>
    
    <string name="faq_q6">Shubhali tranzaksiya nima?</string>
    <string name="faq_a6">Ilova gʻayritabiiy yoki nomaʼlum xarajatlarni sezsa, sizni ogohlantiradi. Bu tranzaksiyalarni \'Shubhali toʻlovlar\' sahifasida koʻrishingiz mumkin.</string>

    <!-- Privacy Policy Content -->
    <string name="privacy_policy_title">Maxfiylik siyosati</string>
    <string name="privacy_last_updated">Oxirgi yangilanish: 20-fevral, 2026-yil</string>
    
    <string name="privacy_title_1">1. Kirish</string>
    <string name="privacy_content_1">Sub Tracker sizning maxfiyligingizni hurmat qiladi. Ushbu siyosat maʼlumotlarning qanday toʻplanishi va himoyalanishini tushuntiradi.</string>
    
    <string name="privacy_title_2">2. Maʼlumotlarni toʻplash</string>
    <string name="privacy_content_2">Biz obunalar, foydalanish tanlovlari va asosiy qurilma maʼlumotlarini toʻplashimiz mumkin.</string>
    
    <string name="privacy_title_3">3. Maʼlumotlardan foydalanish</string>
    <string name="privacy_content_3">Maʼlumotlar obunalarni kuzatish, eslatmalar yuborish va xizmatni yaxshilash uchun ishlatiladi.</string>
    
    <string name="privacy_title_4">4. Xavfsizlik</string>
    <string name="privacy_content_4">Maʼlumotlaringiz standart usullar bilan himoyalangan va hech kimga ruxsatsiz berilmaydi.</string>
    
    <string name="privacy_title_5">5. Ruxsatlar</string>
    <string name="privacy_content_5">Ilova eslatmalarni yuborish uchun bildirishnoma ruxsatini soʻrashi mumkin.</string>
    
    <string name="privacy_title_6">6. Aloqa</string>
    <string name="privacy_content_6">Savollar boʻyicha bizga yozishingiz mumkin: gokhanaytekinn@yandex.com</string>
</resources>
